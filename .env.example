# ===============================
# Sawitea Environment Variables
# ===============================

# Application
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sawitea

# Redis (for Bull Queue)
REDIS_HOST=localhost
REDIS_PORT=6379

# Better Auth
BETTER_AUTH_SECRET=change-this-to-a-32-character-secret-key
BETTER_AUTH_URL=http://localhost:3001

# Mayar.id Payment (https://mayar.id)
# Get your API key from: https://web.mayar.id/api-keys
MAYAR_API_KEY=
MAYAR_WEBHOOK_SECRET=

# OAuth Providers (Optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
