# API App
PORT=3001
FRONTEND_URL=http://localhost:3000

# Database - PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sawitria

# Redis (for Bull Queue)
REDIS_HOST=localhost
REDIS_PORT=6379

# Better Auth Configuration
BETTER_AUTH_SECRET=your-strong-secret-key-min-32-characters-long
BETTER_AUTH_URL=http://localhost:3001

# Mayar.id Payment Configuration
# Get your API key from: https://web.mayar.id/api-keys (Production)
# Sandbox: https://web.mayar.club/api-keys
MAYAR_API_KEY=your-mayar-api-key
MAYAR_WEBHOOK_SECRET=your-mayar-webhook-secret

# OAuth Providers (optional)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret
